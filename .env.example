# Database (Prisma reads directly, no NUXT_ prefix needed)
DATABASE_URL="postgresql://pactery:pactery@localhost:5432/pactery?schema=public"

# ──────────────────────────────────────────────────────────
# Nuxt runtimeConfig: 프로덕션(Docker)에서는 반드시 NUXT_ 접두사 사용
# nuxt build 시 process.env.*는 빌드타임에 평가되어 빈값으로 bake됨
# 런타임 오버라이드는 NUXT_ 접두사만 인식
# 로컬 개발에서는 접두사 없이도 작동 (nuxt dev가 실시간 평가)
# ──────────────────────────────────────────────────────────

# JWT
JWT_SECRET="your-jwt-secret-here"
JWT_EXPIRES_IN="7d"

# App
APP_URL="http://localhost:4540"

# AWS S3
S3_BUCKET="pactery-files"
S3_REGION="ap-northeast-2"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# Resend (Email)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@pactery.com"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Kakao OAuth
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# NCloud SMS (SENS)
NCLOUD_ACCESS_KEY=""
NCLOUD_SECRET_KEY=""
NCLOUD_SMS_SERVICE_ID=""
NCLOUD_SMS_FROM=""

# Claude AI (for field auto-detection)
CLAUDE_API_KEY=""
